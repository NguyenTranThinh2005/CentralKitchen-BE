  "components": {
    "schemas": {
      "CreateOrderDto": {
        "required": [
          "orderItems"
        ],
        "type": "object",
        "properties": {
          "note": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "orderItems": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateOrderItemDto"
            }
          }
        },
        "additionalProperties": false
      },
      "CreateOrderItemDto": {
        "required": [
          "productId",
          "quantity"
        ],
        "type": "object",
        "properties": {
          "productId": {
            "type": "integer",
            "format": "int32"
          },
          "quantity": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "note": {
            "maxLength": 200,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateProductDto": {
        "required": [
          "category",
          "name",
          "unit",
          "unitPrice"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "unit": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "unitPrice": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "category": {
            "$ref": "#/components/schemas/ProductCategory"
          }
        },
        "additionalProperties": false
      },
      "CreateStoreDto": {
        "required": [
          "address",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string"
          },
          "address": {
            "maxLength": 250,
            "minLength": 1,
            "type": "string"
